# 第三方库依赖（vendored dependencies）
# vendor/ 下的文件默认忽略，以下除外：
# - git 子模块（由 .gitmodules 管理，自动追踪 gitlink）
# - vendor/README.md 和 vendor/VERSION.md（项目自身的 vendor 元数据文件）
vendor/*
!vendor/flexloop/
!vendor/README.md
!vendor/VERSION.md

# 任务中间产物
.temp/
.uploads/

# Python 缓存与编译文件
__pycache__/
*.pyc
*.pyo
*.pyd

# 工具脚本缓存（链接检查结果等）
.agents/cache/
.agents/config/discourse/
.agents/scripts/config/forum-state.json
.agents/scripts/config/*-fail-*.png
.agents/scripts/logs/
.agents/logs/
.agents/reports/

# 虚拟环境
.venv/
venv/
env/

# Node.js 依赖
node_modules/

# 环境变量与密钥
.env
.env.local
.env.*.local

# 日志文件
*.log

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 文件
.idea/
*.swp
*.swo
*~

# 构建产物
dist/
build/
*.egg-info/
