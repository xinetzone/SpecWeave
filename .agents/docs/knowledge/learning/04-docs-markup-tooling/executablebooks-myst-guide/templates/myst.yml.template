# ==============================================================================
# MyST Markdown (myst.yml) 配置模板
# ==============================================================================
# 本文件包含 MyST 项目的常用配置项，可根据实际需要取消注释并修改对应值。
#
# 使用方法：
# 1. 复制本文件为 myst.yml 放置于项目根目录
# 2. 根据需要取消注释并修改配置项
# 3. 必填项（version、project、site、template）已启用，无需注释
#
# 官方文档：https://mystmd.org/guide/configuration
# ==============================================================================

version: 1

project:
  # --------------------------------------------------------------------------
  # 项目基本信息
  # --------------------------------------------------------------------------
  title: "我的项目标题"
  description: "项目描述"
  keywords: []
  # keywords:
  #   - "关键词1"
  #   - "关键词2"
  #   - "MyST"

  # --------------------------------------------------------------------------
  # 作者信息（可添加多个作者）
  # --------------------------------------------------------------------------
  authors:
    - name: "作者姓名"
      orcid: "https://orcid.org/0000-0000-0000-0000"
      corresponding: true
      email: "author@example.com"
      roles:
        - "Conceptualization"
        - "Writing - original draft"
      affiliations:
        - "机构ID1"
    # - name: "第二作者"
    #   orcid: "https://orcid.org/0000-0000-0000-0000"
    #   corresponding: false
    #   email: "author2@example.com"
    #   roles:
    #     - "Methodology"
    #     - "Visualization"
    #   affiliations:
    #     - "机构ID1"

  # --------------------------------------------------------------------------
  # 机构信息（通过ID与作者关联）
  # --------------------------------------------------------------------------
  # affiliations:
  #   - id: "机构ID1"
  #     name: "机构全称"
  #     department: "院系/部门名称"
  #     address: "地址"
  #     city: "城市"
  #     state: "省/州"
  #     postal_code: "邮编"
  #     country: "国家"
  #     url: "https://institution.example.com"

  # --------------------------------------------------------------------------
  # 许可证
  # --------------------------------------------------------------------------
  license: CC-BY-4.0
  # 其他常用开源许可：CC0-1.0, CC-BY-SA-4.0, MIT, Apache-2.0

  # --------------------------------------------------------------------------
  # GitHub 仓库（用于生成"在GitHub上编辑"等链接）
  # --------------------------------------------------------------------------
  github: owner/repo

  # --------------------------------------------------------------------------
  # 参考文献文件（支持 BibTeX 格式）
  # --------------------------------------------------------------------------
  bibliography: []
  # bibliography:
  #   - "references.bib"

  # --------------------------------------------------------------------------
  # 数学宏定义（可选，用于 LaTeX 数学公式）
  # --------------------------------------------------------------------------
  # math:
  #   macros:
  #     "\\RR": "\\mathbb{R}"
  #     "\\dd": "\\mathrm{d}"

  # --------------------------------------------------------------------------
  # 目录结构（TOC - Table of Contents）配置
  # --------------------------------------------------------------------------
  # TOC 定义文档的导航结构，支持以下字段：
  # - file: 指向 .md 或 .ipynb 文件的路径（相对路径）
  # - title: 显示在导航中的标题（可选，默认使用文件标题）
  # - children: 子章节列表（嵌套结构）
  # - pattern: 使用 glob 模式匹配多个文件（如 "chapters/*.md"）
  # - url: 外部链接（非本地文档）
  # - hidden: true/false，是否在导航中隐藏该条目
  toc:
    - file: index.md
      title: "首页"
    - file: 01-getting-started.md
      title: "快速开始"
      children:
        - file: 01-01-installation.md
          title: "安装指南"
        - file: 01-02-first-steps.md
          title: "第一步"
    # - file: 02-features.md
    #   title: "功能特性"
    # - pattern: "appendices/*.md"
    # - title: "外部资源"
    #   url: "https://mystmd.org"
    # - file: draft-notes.md
    #   hidden: true

  # --------------------------------------------------------------------------
  # 导出配置（可选，用于导出为 PDF/Word/LaTeX 等格式）
  # --------------------------------------------------------------------------
  # exports:
  #   - format: pdf
  #     template: arxiv_two_column
  #     output: exports/paper.pdf
  #     articles:
  #       - index.md
  #   - format: docx
  #     output: exports/paper.docx
  #     articles:
  #       - index.md
  #   - format: tex
  #     template: arxiv_two_column
  #     output: exports/paper.tex
  #     articles:
  #       - index.md

site:
  # --------------------------------------------------------------------------
  # 网站主题模板（三选一）
  # - book-theme: 书籍主题（适合长篇文档、教程、书籍）
  # - article-theme: 文章主题（适合单篇论文、文章）
  # - slide-theme: 幻灯片主题（适合演示文稿）
  # --------------------------------------------------------------------------
  template: book-theme

  # --------------------------------------------------------------------------
  # 网站标题（显示在浏览器标签页和导航栏）
  # --------------------------------------------------------------------------
  title: "我的网站"

  # --------------------------------------------------------------------------
  # 网站选项
  # --------------------------------------------------------------------------
  # options:
  #   logo: logo.png
  #   favicon: favicon.ico
  #   twitter: "@mystmd"
  #   analytics_plausible: mystmd.org
  #   outline: [1, 2]
  #   hide_outline: false
  #   hide_footer_links: false

  # --------------------------------------------------------------------------
  # 导航栏（顶部导航链接，用于跨页面导航）
  # --------------------------------------------------------------------------
  nav:
    - title: "文档"
      url: "/"
    - title: "教程"
      children:
        - title: "快速开始"
          url: "/01-getting-started"
        - title: "语法指南"
          url: "/syntax"
    # - title: "API参考"
    #   url: "/api"

  # --------------------------------------------------------------------------
  # 操作按钮（显示在导航栏右侧的行动号召按钮）
  # --------------------------------------------------------------------------
  actions:
    - title: "Learn More"
      url: "https://mystmd.org/guide"
    # - title: "GitHub"
    #   url: "https://github.com/owner/repo"
    #   static: true

  # --------------------------------------------------------------------------
  # 域名配置（可选，用于自定义域名部署）
  # --------------------------------------------------------------------------
  # domains:
  #   - "example.com"
  #   - "www.example.com"

# ==============================================================================
# 使用提示
# ==============================================================================
# 1. 运行 `myst init` 可交互式生成基础配置文件
# 2. 项目结构与 frontmatter 配置请参考：
#    - 02-project-structure.md（项目结构说明）
#    - 03-frontmatter-config.md（frontmatter 配置指南）
# 3. TOC 配置详细说明请参考：
#    - 04-table-of-contents.md（目录配置指南）
# 4. 完整配置选项见官方文档：
#    https://mystmd.org/guide/configuration
# ==============================================================================
